---
import PortfolioCollection from '../components/PortfolioCollection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    id: 'art',
    title: 'Art & Design',
    subtitle: 'Visual explorations at the intersection of code and creativity',
    color: '#ff006e',
    source: 'art.xaostech.io',
    projects: [
      {
        title: 'Generative Visuals',
        description: 'Procedural art created with WebGL shaders, particle systems, and algorithmic composition. Each piece is unique and interactive.',
        tags: ['WebGL', 'GLSL', 'Three.js', 'Generative'],
        href: 'https://art.xaostech.io',
        status: 'experimental' as const,
      },
      {
        title: 'Music & Audio',
        description: 'Audio-reactive visualisations and music compositions. Home of The Trove — a curated journal of sound and synthesis.',
        tags: ['Web Audio', 'Synthesis', 'Visualisation'],
        href: 'https://music.xaostech.io',
        status: 'beta' as const,
      },
    ],
  },
  {
    id: 'foss',
    title: 'Free & Open Source',
    subtitle: 'Tools and platforms built in the open',
    color: '#00ff88',
    source: 'github.com/XAOSTECH',
    projects: [
      {
        title: 'XAOSTECH Platform',
        description: 'The full-stack cloud-native platform powering all XAOSTECH services. 12 microservices on Cloudflare Workers with D1, KV, R2, and Workers AI.',
        tags: ['Cloudflare', 'Hono', 'Astro', 'TypeScript'],
        href: 'https://github.com/XAOSTECH/XAOSTECH',
        status: 'stable' as const,
      },
      {
        title: 'Lingua Engine',
        description: 'AI-powered multilingual translation and language processing with dictionary support for 100+ languages.',
        tags: ['AI', 'NLP', 'Translation', 'Workers AI'],
        href: 'https://lingua.xaostech.io',
        status: 'beta' as const,
      },
      {
        title: 'Edu Platform',
        description: 'Educational exercise framework with parental controls, age-appropriate content filtering, and progress tracking.',
        tags: ['Education', 'Parental Controls', 'KV'],
        href: 'https://edu.xaostech.io',
        status: 'beta' as const,
      },
    ],
  },
  {
    id: 'infrastructure',
    title: 'Infrastructure',
    subtitle: 'The backbone: APIs, auth, payments, and data privacy',
    color: '#00c8ff',
    source: 'api.xaostech.io',
    projects: [
      {
        title: 'API Gateway',
        description: 'Central API hub with authentication, rate limiting, content moderation, and request validation.',
        tags: ['REST', 'Hono', 'Auth', 'Rate Limiting'],
        href: 'https://api.xaostech.io',
        status: 'stable' as const,
      },
      {
        title: 'Account & Identity',
        description: 'OAuth 2.0 authentication, session management, family accounts, and multi-tenant user infrastructure.',
        tags: ['OAuth', 'Sessions', 'Family', 'KV'],
        href: 'https://account.xaostech.io',
        status: 'stable' as const,
      },
      {
        title: 'Payments',
        description: 'Stripe integration with subscription management, family billing, and webhook-verified payment processing.',
        tags: ['Stripe', 'Billing', 'Webhooks'],
        href: 'https://payments.xaostech.io',
        status: 'beta' as const,
      },
      {
        title: 'Data Privacy',
        description: 'GDPR-compliant consent management with audit trails and encrypted storage.',
        tags: ['GDPR', 'Privacy', 'Consent'],
        href: 'https://data.xaostech.io',
        status: 'stable' as const,
      },
    ],
  },
  {
    id: 'content',
    title: 'Content & Communication',
    subtitle: 'Publishing, discussion, and real-time messaging',
    color: '#ffbe0b',
    source: 'blog.xaostech.io',
    projects: [
      {
        title: 'Blog Platform',
        description: 'Distributed content management with real-time caching, D1 database backend, and R2 media storage.',
        tags: ['Astro', 'D1', 'KV', 'R2'],
        href: 'https://blog.xaostech.io',
        status: 'stable' as const,
      },
      {
        title: 'Chat',
        description: 'Real-time AI-powered chat interface with streaming responses and conversation persistence.',
        tags: ['Workers AI', 'Streaming', 'KV'],
        href: 'https://chat.xaostech.io',
        status: 'beta' as const,
      },
    ],
  },
];
---

<BaseLayout title="Portfolio - XAOSTECH" description="Art, code, and infrastructure at the intersection of chaos and technology">
  <PortfolioCollection sections={sections} />
</BaseLayout>
