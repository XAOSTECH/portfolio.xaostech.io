---
export interface ProjectItem {
  title: string;
  description: string;
  tags: string[];
  href: string;
  status?: 'beta' | 'stable' | 'experimental';
}

export interface Section {
  id: string;
  title: string;
  subtitle: string;
  color: string;
  source: string;
  projects: ProjectItem[];
}

export interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<div class="portfolio-container">
  <canvas id="particle-canvas"></canvas>

  <div class="portfolio-overlay">
    <header class="portfolio-header">
      <h1>XAOSTECH</h1>
      <p class="subtitle">Art · Code · Infrastructure</p>
      <nav class="section-nav">
        {sections.map((s) => (
          <a href={`#${s.id}`} style={`--accent: ${s.color}`}>{s.title}</a>
        ))}
      </nav>
    </header>

    {sections.map((section) => (
      <section id={section.id} class="portfolio-section" style={`--accent: ${section.color}`}>
        <div class="section-header">
          <h2>{section.title}</h2>
          <p class="section-subtitle">{section.subtitle}</p>
          <span class="section-source">{section.source}</span>
        </div>
        <div class="projects-grid">
          {section.projects.map((project) => (
            <a href={project.href} class="project-card" data-status={project.status}>
              <div class="project-header">
                <h3>{project.title}</h3>
                {project.status && <span class="status-badge">{project.status}</span>}
              </div>
              <p class="project-description">{project.description}</p>
              <div class="project-tags">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <span class="project-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    ))}

    <footer class="portfolio-footer">
      <p>&copy; 2026 XAOSTECH. All rights reserved.</p>
      <a href="https://xaostech.io">← Back to Home</a>
    </footer>
  </div>
</div>

<script>
  class ParticleAnimation {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    particles: any[] = [];
    mouse = { x: 0, y: 0 };
    animationId: number | null = null;

    constructor(canvasId: string) {
      this.canvas = document.getElementById(canvasId) as HTMLCanvasElement;
      this.ctx = this.canvas.getContext('2d')!;
      this.resize();
      this.setupParticles();
      this.setupEventListeners();
      this.animate();
    }

    resize() {
      const container = this.canvas.parentElement!;
      this.canvas.width = container.scrollWidth;
      this.canvas.height = container.scrollHeight;
    }

    setupParticles() {
      const particleCount = 60;
      for (let i = 0; i < particleCount; i++) {
        this.particles.push({
          x: Math.random() * this.canvas.width,
          y: Math.random() * this.canvas.height,
          vx: (Math.random() - 0.5) * 1.5,
          vy: (Math.random() - 0.5) * 1.5,
          radius: Math.random() * 2 + 1,
          life: Math.random() * 100 + 50,
          maxLife: 150,
          hue: Math.random() * 360,
        });
      }
    }

    setupEventListeners() {
      const ro = new ResizeObserver(() => this.resize());
      ro.observe(this.canvas.parentElement!);
      document.addEventListener('mousemove', (e) => {
        this.mouse.x = e.clientX;
        this.mouse.y = e.clientY + window.scrollY;
      });
    }

    update() {
      this.particles.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;

        const dx = this.mouse.x - p.x;
        const dy = this.mouse.y - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < 150) {
          p.vx += (dx / dist) * 0.05;
          p.vy += (dy / dist) * 0.05;
        }

        p.vx *= 0.98;
        p.vy *= 0.98;

        if (p.x < 0 || p.x > this.canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > this.canvas.height) p.vy *= -1;

        p.x = Math.max(0, Math.min(this.canvas.width, p.x));
        p.y = Math.max(0, Math.min(this.canvas.height, p.y));

        p.life--;
        if (p.life < 0) {
          p.x = Math.random() * this.canvas.width;
          p.y = Math.random() * this.canvas.height;
          p.life = p.maxLife;
        }
      });
    }

    draw() {
      this.ctx.fillStyle = 'rgba(10, 10, 20, 0.15)';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      this.particles.forEach((p) => {
        const opacity = (p.life / p.maxLife) * 0.8;
        this.ctx.fillStyle = `hsla(${p.hue}, 100%, 60%, ${opacity})`;
        this.ctx.beginPath();
        this.ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        this.ctx.fill();

        this.particles.forEach((p2) => {
          const dx = p.x - p2.x;
          const dy = p.y - p2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 100 && dist > 0) {
            const lineOpacity = (1 - dist / 100) * opacity * 0.5;
            this.ctx.strokeStyle = `hsla(${p.hue}, 100%, 60%, ${lineOpacity})`;
            this.ctx.lineWidth = 1;
            this.ctx.beginPath();
            this.ctx.moveTo(p.x, p.y);
            this.ctx.lineTo(p2.x, p2.y);
            this.ctx.stroke();
          }
        });
      });
    }

    animate = () => {
      this.update();
      this.draw();
      this.animationId = requestAnimationFrame(this.animate);
    };
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => new ParticleAnimation('particle-canvas'));
  } else {
    new ParticleAnimation('particle-canvas');
  }
</script>

<style>
  .portfolio-container {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: linear-gradient(135deg, #0a0a14 0%, #1a0a2e 100%);
  }

  #particle-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }

  .portfolio-overlay {
    position: relative;
    z-index: 10;
    padding: 3rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .portfolio-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-top: 2rem;
  }

  .portfolio-header h1 {
    font-size: 4rem;
    font-weight: 700;
    margin: 0;
    background: linear-gradient(90deg, #ff006e 0%, #ffbe0b 50%, #00c8ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0.2em;
  }

  .subtitle {
    font-size: 1.2rem;
    color: #888;
    margin: 0.75rem 0 0 0;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: lowercase;
  }

  .section-nav {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .section-nav a {
    color: var(--accent, #aaa);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .section-nav a:hover {
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    border-color: var(--accent);
  }

  .portfolio-section {
    margin-bottom: 4rem;
    scroll-margin-top: 2rem;
  }

  .section-header {
    margin-bottom: 2rem;
    padding-left: 1rem;
    border-left: 3px solid var(--accent, #ffbe0b);
  }

  .section-header h2 {
    font-size: 2rem;
    font-weight: 600;
    margin: 0;
    color: #fff;
  }

  .section-subtitle {
    font-size: 0.95rem;
    color: #999;
    margin: 0.3rem 0 0 0;
  }

  .section-source {
    font-size: 0.75rem;
    color: #555;
    font-family: monospace;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--accent, #ffbe0b) 25%, transparent);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.03);
    color: #fff;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    overflow: hidden;
    backdrop-filter: blur(4px);
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--accent, #ffbe0b) 8%, transparent), transparent);
    transition: left 0.5s ease;
  }

  .project-card:hover {
    border-color: var(--accent, #ffbe0b);
    background: color-mix(in srgb, var(--accent, #ffbe0b) 8%, transparent);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px color-mix(in srgb, var(--accent, #ffbe0b) 15%, transparent);
  }

  .project-card:hover::before {
    left: 100%;
  }

  .project-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    gap: 1rem;
  }

  .project-header h3 {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
    text-align: left;
  }

  .status-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    background: rgba(0, 255, 136, 0.15);
    border: 1px solid rgba(0, 255, 136, 0.4);
    color: #00ff88;
  }

  .project-card[data-status='beta'] .status-badge {
    background: rgba(255, 190, 11, 0.15);
    border-color: rgba(255, 190, 11, 0.4);
    color: #ffbe0b;
  }

  .project-card[data-status='experimental'] .status-badge {
    background: rgba(255, 106, 146, 0.15);
    border-color: rgba(255, 106, 146, 0.4);
    color: #ff6a92;
  }

  .project-description {
    margin: 0 0 1rem 0;
    font-size: 0.9rem;
    color: #bbb;
    line-height: 1.5;
    text-align: left;
    flex-grow: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.45rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 3px;
    font-size: 0.7rem;
    color: #aaa;
  }

  .project-arrow {
    align-self: flex-end;
    font-size: 1.3rem;
    color: #555;
    transition: all 0.3s ease;
  }

  .project-card:hover .project-arrow {
    transform: translateX(4px);
    color: var(--accent, #ffbe0b);
  }

  .portfolio-footer {
    padding: 2rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.85rem;
    color: #555;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .portfolio-footer p { margin: 0; }

  .portfolio-footer a {
    color: #888;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .portfolio-footer a:hover { color: #fff; }

  @media (max-width: 768px) {
    .portfolio-header h1 { font-size: 2.5rem; }
    .section-header h2 { font-size: 1.5rem; }
    .projects-grid { grid-template-columns: 1fr; }
    .portfolio-footer { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>
